configfile: "spo11_variation/config/config.yaml"

from pathlib import Path

PROJECT_NAME = config["project_name"]

GENE_ID = config["gene"]["gene_id"]
GENE_NAME = config["gene"]["gene_name"]

TRANSCRIPTS = config["transcripts"]

GENOME_FA = config["paths"]["genome_fa"]
ANNOTATION_GFF = config["paths"]["annotation_gff"]
HAPMAP_VCF = config["paths"]["hapmap_vcf"]
PROJECT_INPUTS_DIR = config["paths"]["project_inputs_dir"]

RESULTS = config["results_dir"]

PLOT_MIN_PCT_FULL = config.get("plot", {}).get("min_pct_full", 0.2)
PLOT_MIN_PCT_NONREF = config.get("plot", {}).get("min_pct_nonref", 0.15)
PLOT_WIDTH = config.get("plot", {}).get("width", 18)
PLOT_HEIGHT = config.get("plot", {}).get("height", 4.2)
PLOT_LEGEND_NCOL = config.get("plot", {}).get("legend_ncol", 8)

PROJECT_GENE_GFF = f"{PROJECT_INPUTS_DIR}/{GENE_NAME}.gene.gff3"
PROJECT_TX_GFF = f"{PROJECT_INPUTS_DIR}/{GENE_NAME}.transcripts.gff3"

BED_FA_DIR = f"{RESULTS}/01_models/bed_fa"
BED_VCF_DIR = f"{RESULTS}/01_models/bed_vcf"
BLOCKMAP_DIR = f"{RESULTS}/01_models/blockmap"

BLOCKS_DIR = f"{RESULTS}/02_sequences/blocks"
CDS_DIR = f"{RESULTS}/02_sequences/cds"
PEP_DIR = f"{RESULTS}/02_sequences/pep"
PEP_NOSTOP_DIR = f"{RESULTS}/02_sequences/pep_nostop"

VAR_REGION_DIR = f"{RESULTS}/03_variants/region"
CDS_VAR_DIR = f"{RESULTS}/03_variants/cds_by_transcript"
EFFECTS_DIR = f"{RESULTS}/03_variants/effects"
GENO_TX_DIR = f"{RESULTS}/03_variants/genotypes_by_transcript"

REPORTS_DIR = f"{RESULTS}/04_reports"
LOGS_DIR = f"{RESULTS}/logs"

VALIDATION_OK = f"{LOGS_DIR}/validate_inputs.ok"

REGION_VARIANTS_TSV = f"{VAR_REGION_DIR}/{GENE_NAME}.region.variants.tsv"
REGION_GENOTYPES_VCF = f"{VAR_REGION_DIR}/{GENE_NAME}.region.genotypes.vcf"

SITE_SUMMARY_TSV = f"{REPORTS_DIR}/{GENE_NAME}.cds_site_summary.tsv"
TRANSCRIPT_SUMMARY_TSV = f"{REPORTS_DIR}/{GENE_NAME}.transcript_summary.tsv"


def cds_bed_fa(t):
    return f"{BED_FA_DIR}/{GENE_ID}_{t}.cds.bed"


def cds_bed_vcf(t):
    return f"{BED_VCF_DIR}/{GENE_ID}_{t}.cds.bed"


def blockmap_tsv(t):
    return f"{BLOCKMAP_DIR}/{t}.cds.blockmap.tsv"


def cds_blocks_tsv(t):
    return f"{BLOCKS_DIR}/{t}.cds.blocks.tsv"


def cds_fa(t):
    return f"{CDS_DIR}/{GENE_ID}_{t}.cds.fa"


def pep_fa(t):
    return f"{PEP_DIR}/{GENE_ID}_{t}.pep.fa"


def pep_nostop_fa(t):
    return f"{PEP_NOSTOP_DIR}/{GENE_ID}_{t}.pep.nostop.fa"


def cds_variants_tsv(t):
    return f"{CDS_VAR_DIR}/{GENE_NAME}.{t}.CDS.variants.tsv"


def effects_tsv(t):
    return f"{EFFECTS_DIR}/{GENE_NAME}.{t}.CDS.variant_effects.tsv"


def genotype_vcf_t(t):
    return f"{GENO_TX_DIR}/{GENE_NAME}.{t}.CDS.genotypes.vcf"


def aa_freq_long_tsv(t):
    return f"{REPORTS_DIR}/{GENE_NAME}.{t}.aa_freq.long.tsv"


def aa_freq_matrix_tsv(t):
    return f"{REPORTS_DIR}/{GENE_NAME}.{t}.aa_freq.matrix.tsv"


def aa_freq_plot_full_png(t):
    return f"{REPORTS_DIR}/{GENE_NAME}.{t}.aa_freq.stacked.full.final.png"


def aa_freq_plot_nonref_png(t):
    return f"{REPORTS_DIR}/{GENE_NAME}.{t}.aa_freq.stacked.nonref.final.png"


rule all:
    input:
        VALIDATION_OK,

        expand(cds_bed_fa("{t}"), t=TRANSCRIPTS),
        expand(cds_bed_vcf("{t}"), t=TRANSCRIPTS),
        expand(blockmap_tsv("{t}"), t=TRANSCRIPTS),

        expand(cds_blocks_tsv("{t}"), t=TRANSCRIPTS),
        expand(cds_fa("{t}"), t=TRANSCRIPTS),
        expand(pep_fa("{t}"), t=TRANSCRIPTS),
        expand(pep_nostop_fa("{t}"), t=TRANSCRIPTS),

        REGION_VARIANTS_TSV,
        expand(cds_variants_tsv("{t}"), t=TRANSCRIPTS),
        expand(effects_tsv("{t}"), t=TRANSCRIPTS),

        SITE_SUMMARY_TSV,
        TRANSCRIPT_SUMMARY_TSV,

        REGION_GENOTYPES_VCF,
        expand(genotype_vcf_t("{t}"), t=TRANSCRIPTS),

        expand(aa_freq_long_tsv("{t}"), t=TRANSCRIPTS),
        expand(aa_freq_matrix_tsv("{t}"), t=TRANSCRIPTS),

        expand(aa_freq_plot_full_png("{t}"), t=TRANSCRIPTS),
        expand(aa_freq_plot_nonref_png("{t}"), t=TRANSCRIPTS),


rule validate_inputs:
    input:
        fasta=GENOME_FA,
        project_gff=PROJECT_TX_GFF,
        annotation_gff=ANNOTATION_GFF,
        vcf=HAPMAP_VCF,
    output:
        touch(VALIDATION_OK)
    shell:
        r"""
        mkdir -p {LOGS_DIR}
        python spo11_variation/scripts/validate_inputs.py \
          --fasta {input.fasta} \
          --project-gff {input.project_gff} \
          --annotation-gff {input.annotation_gff} \
          --vcf {input.vcf}
        touch {output}
        """


rule build_cds_beds:
    input:
        VALIDATION_OK,
        project_gff=PROJECT_TX_GFF,
        annotation_gff=ANNOTATION_GFF,
    output:
        bed_fa=expand(cds_bed_fa("{t}"), t=TRANSCRIPTS),
        bed_vcf=expand(cds_bed_vcf("{t}"), t=TRANSCRIPTS),
    shell:
        r"""
        python spo11_variation/scripts/build_cds_bed_from_gff.py \
          --project-gff {input.project_gff} \
          --annotation-gff {input.annotation_gff} \
          --out-bed-fa-dir {BED_FA_DIR} \
          --out-bed-vcf-dir {BED_VCF_DIR}
        """


rule build_blockmap:
    input:
        bed=cds_bed_vcf("{t}")
    output:
        blockmap_tsv("{t}")
    shell:
        r"""
        python spo11_variation/scripts/build_blockmap.py \
          --bed {input.bed} \
          --out {output}
        """


rule extract_cds_fasta:
    input:
        genome=GENOME_FA,
        bed=cds_bed_fa("{t}")
    output:
        blocks=cds_blocks_tsv("{t}"),
        cds=cds_fa("{t}")
    shell:
        r"""
        python spo11_variation/scripts/extract_cds_fasta.py \
          --genome {input.genome} \
          --bed {input.bed} \
          --out-blocks {output.blocks} \
          --out-cds {output.cds}
        """


rule translate_cds_to_pep:
    input:
        cds=cds_fa("{t}")
    output:
        pep=pep_fa("{t}"),
        pep_nostop=pep_nostop_fa("{t}")
    shell:
        r"""
        python spo11_variation/scripts/translate_cds_to_pep.py \
          --cds {input.cds} \
          --out-pep {output.pep} \
          --out-pep-nostop {output.pep_nostop}
        """


rule extract_region_variants:
    input:
        gene_gff=PROJECT_GENE_GFF,
        vcf=HAPMAP_VCF
    output:
        REGION_VARIANTS_TSV
    shell:
        r"""
        python spo11_variation/scripts/extract_region_variants_from_vcf.py \
          --gene-gff {input.gene_gff} \
          --vcf {input.vcf} \
          --out {output}
        """


rule subset_variants_by_bed:
    input:
        bed=cds_bed_vcf("{t}"),
        variants=REGION_VARIANTS_TSV
    output:
        cds_variants_tsv("{t}")
    shell:
        r"""
        python spo11_variation/scripts/subset_variants_by_bed.py \
          --bed {input.bed} \
          --variants {input.variants} \
          --out {output}
        """


rule annotate_cds_variants:
    input:
        blockmap=blockmap_tsv("{t}"),
        cds=cds_fa("{t}"),
        variants=cds_variants_tsv("{t}")
    output:
        effects_tsv("{t}")
    shell:
        r"""
        python spo11_variation/scripts/annotate_cds_variants.py \
          --blockmap {input.blockmap} \
          --cds {input.cds} \
          --variants {input.variants} \
          > {output}
        """


rule summarize_cds_sites:
    input:
        expand(effects_tsv("{t}"), t=TRANSCRIPTS)
    output:
        SITE_SUMMARY_TSV
    shell:
        r"""
        python spo11_variation/scripts/summarize_cds_sites.py \
          --effects {input} \
          --out {output}
        """


rule summarize_transcripts:
    input:
        cds=expand(cds_fa("{t}"), t=TRANSCRIPTS),
        pep=expand(pep_fa("{t}"), t=TRANSCRIPTS),
        pep_nostop=expand(pep_nostop_fa("{t}"), t=TRANSCRIPTS),
        variants=expand(cds_variants_tsv("{t}"), t=TRANSCRIPTS),
        effects=expand(effects_tsv("{t}"), t=TRANSCRIPTS),
        site_summary=SITE_SUMMARY_TSV
    output:
        TRANSCRIPT_SUMMARY_TSV
    shell:
        r"""
        python spo11_variation/scripts/summarize_transcripts.py \
          --cds {input.cds} \
          --pep {input.pep} \
          --pep-nostop {input.pep_nostop} \
          --variants {input.variants} \
          --effects {input.effects} \
          --site-summary {input.site_summary} \
          --out {output}
        """


rule extract_region_genotypes:
    input:
        gene_gff=PROJECT_GENE_GFF,
        vcf=HAPMAP_VCF
    output:
        REGION_GENOTYPES_VCF
    shell:
        r"""
        python spo11_variation/scripts/extract_region_genotypes_from_vcf.py \
          --gene-gff {input.gene_gff} \
          --vcf {input.vcf} \
          --out {output}
        """


rule subset_genotypes_by_bed:
    input:
        bed=cds_bed_vcf("{t}"),
        vcf=REGION_GENOTYPES_VCF
    output:
        genotype_vcf_t("{t}")
    shell:
        r"""
        python spo11_variation/scripts/subset_genotypes_by_bed.py \
          --bed {input.bed} \
          --vcf {input.vcf} \
          --out {output}
        """


rule build_aa_frequency_matrix:
    input:
        cds=cds_fa("{t}"),
        effects=effects_tsv("{t}"),
        vcf=genotype_vcf_t("{t}")
    output:
        long=aa_freq_long_tsv("{t}"),
        matrix=aa_freq_matrix_tsv("{t}")
    shell:
        r"""
        python spo11_variation/scripts/build_aa_frequency_matrix_from_vcf.py \
          --cds {input.cds} \
          --effects {input.effects} \
          --vcf {input.vcf} \
          --out-long {output.long} \
          --out-matrix {output.matrix}
        """


rule plot_aa_frequency_full:
    input:
        matrix=aa_freq_matrix_tsv("{t}")
    output:
        aa_freq_plot_full_png("{t}")
    shell:
        r"""
        python spo11_variation/scripts/plot_aa_frequency_stacked.py \
          --in-matrix {input.matrix} \
          --out-png {output} \
          --title "{GENE_NAME} {wildcards.t} – Amino acid composition by position" \
          --min-pct {PLOT_MIN_PCT_FULL} \
          --legend-ncol {PLOT_LEGEND_NCOL} \
          --width {PLOT_WIDTH} \
          --height {PLOT_HEIGHT}
        """


rule plot_aa_frequency_nonref:
    input:
        matrix=aa_freq_matrix_tsv("{t}")
    output:
        aa_freq_plot_nonref_png("{t}")
    shell:
        r"""
        python spo11_variation/scripts/plot_aa_frequency_stacked.py \
          --in-matrix {input.matrix} \
          --out-png {output} \
          --title "{GENE_NAME} {wildcards.t} – Non-reference amino acid frequencies by position" \
          --min-pct {PLOT_MIN_PCT_NONREF} \
          --legend-ncol {PLOT_LEGEND_NCOL} \
          --width {PLOT_WIDTH} \
          --height {PLOT_HEIGHT} \
          --compress-reference \
          --show-variable-rug
        """
